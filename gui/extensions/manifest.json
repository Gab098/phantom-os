{
  "version": "0.1.0",
  "extension_api": "1.0",
  "capabilities": {
    "ui": ["panel", "widget", "notification", "tray"],
    "system": ["fs", "process", "network", "privacy"],
    "ai": ["terminal", "completion", "voice"]
